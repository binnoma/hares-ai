generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Analysis {
  id            String   @id @default(cuid())
  fileName      String
  fileSize      Int
  fileType      String   // apk, ipa
  status        String   // uploading, analyzing, ai-analyzing, completed, failed
  appInfo       String   // JSON string - app name, package, version, etc.
  permissions   String   // JSON string - array of permissions
  files         String   // JSON string - array of files in the APK
  libraries     String   // JSON string - array of libraries
  apiEndpoints  String   // JSON string - array of API endpoints found
  sensitiveStrings String // JSON string - array of sensitive strings
  risks         String   // JSON string - array of risk findings
  aiAnalysis    String   // JSON string - AI analysis results
  riskScore     Int      @default(0) // 0-100 risk score
  reportHtml    String?  // Generated HTML report
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
